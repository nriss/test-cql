     ]
  ] ;
  fhir:Library.description [ fhir:value "Bibliothèque CQL — cas 02 (ROR) : identifie les Organization qui, ayant un HealthcareService avec une activité opérationnelle 157 ou 249 et un mode de prise en charge 33, n'ont pas \"urgence\" dans leur nom."] ;
  fhir:Library.jurisdiction [
