     fhir:Narrative.div "<div xml:lang=\"fr\" lang=\"fr\"><hr/><p><b>French</b></p><hr/><p class=\"res-header-id\"><b>Narratif généré : Organisation org-ch-exemple</b></p><a name=\"org-ch-exemple\"> </a><a name=\"hcorg-ch-exemple\"> </a><p><b>active</b>: true</p><p><b>name</b>: CH Exemple</p></div>"
  ] ;
